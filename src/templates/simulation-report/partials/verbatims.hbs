<div class="page">
  <div class="page-header">
    <div class="page-header-left">{{project.name}}</div>
    <div class="page-header-right">Voces del Panel</div>
  </div>

  <h2>Voces del Panel</h2>

  <div class="verbatims-grid">
    {{#each verbatims}}
      <div class="verbatim-card {{sentiment}}">
        <div class="verbatim-top">
          <div>
            <div class="verbatim-author">{{name}}, {{age}} años</div>
            <div class="verbatim-tags">{{country}} · {{segment}}</div>
          </div>
          <div class="verbatim-right">
            <span class="sentiment-badge {{sentiment}}">{{sentimentLabel sentiment}}</span>
            {{{intentStars intent}}}
          </div>
        </div>
        <div class="verbatim-quote">{{{cleanQuote text 300}}}</div>
      </div>
    {{/each}}
  </div>
</div>
