<div class="page">
  <div class="page-header">
    <div class="page-header-left">{{project.name}}</div>
    <div class="page-header-right">Síntesis Ejecutiva</div>
  </div>

  <h2>Síntesis Ejecutiva</h2>

  <div class="exec-summary-text">
    {{{stripMarkdown insights.executiveSummary}}}
  </div>

  <div class="kpi-grid">
    <div class="kpi-card intent">
      <div class="kpi-value">{{insights.purchaseIntentAvg}}<span style="font-size:14pt;font-weight:400;color:#93c5fd;">/5</span></div>
      <div class="kpi-label">Intención de Compra</div>
      <div class="kpi-sub">Promedio de {{simulation.agentCount}} agentes</div>
    </div>
    <div class="kpi-card price">
      <div class="kpi-value"><span style="font-size:14pt;font-weight:400;color:#86efac;">$</span>{{insights.priceConsensus}}</div>
      <div class="kpi-label">Precio Justo</div>
      <div class="kpi-sub">Consenso del panel</div>
    </div>
    <div class="kpi-card recommend">
      <div class="kpi-value">{{insights.recommendRate}}<span style="font-size:14pt;font-weight:400;color:#c4b5fd;">%</span></div>
      <div class="kpi-label">Tasa de Recomendación</div>
      <div class="kpi-sub">Recomendaría el producto</div>
    </div>
  </div>

  <div class="sim-meta-grid">
    <div class="sim-meta-card">
      <div class="sim-meta-value">{{simulation.agentCount}}</div>
      <div class="sim-meta-label">Agentes</div>
    </div>
    <div class="sim-meta-card">
      <div class="sim-meta-value">{{simulation.rounds}}</div>
      <div class="sim-meta-label">Rounds</div>
    </div>
    <div class="sim-meta-card">
      <div class="sim-meta-value">{{simulation.durationSeconds}}s</div>
      <div class="sim-meta-label">Duración</div>
    </div>
  </div>
</div>
