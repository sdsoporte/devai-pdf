<div class="page">
  <h2>Síntesis Ejecutiva</h2>
  <p>{{insights.executiveSummary}}</p>

  <div class="metrics">
    <div class="metric">
      <div class="value">{{insights.purchaseIntentAvg}}</div>
      <div class="label">Intención de compra</div>
    </div>
    <div class="metric">
      <div class="value">${{insights.priceConsensus}}</div>
      <div class="label">Precio justo</div>
    </div>
    <div class="metric">
      <div class="value">{{insights.recommendRate}}%</div>
      <div class="label">Recomendación</div>
    </div>
  </div>

  <div class="metrics">
    <div class="metric">
      <div class="value">{{simulation.agentCount}}</div>
      <div class="label">Agentes</div>
    </div>
    <div class="metric">
      <div class="value">{{simulation.rounds}}</div>
      <div class="label">Rounds</div>
    </div>
    <div class="metric">
      <div class="value">${{simulation.costUsd}}</div>
      <div class="label">Costo USD</div>
    </div>
    <div class="metric">
      <div class="value">{{simulation.durationSeconds}}s</div>
      <div class="label">Duración</div>
    </div>
  </div>
</div>
