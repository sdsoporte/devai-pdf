<div class="page">
  <div class="page-header">
    <div class="page-header-left">{{project.name}}</div>
    <div class="page-header-right">Hallazgos Cuantitativos</div>
  </div>

  <h2>Hallazgos</h2>

  <div class="chart-section">
    <div class="chart-label">Distribución de intención de compra (1–5)</div>
    <svg viewBox="0 0 440 140" width="100%" height="140" style="display:block;">
      {{#each charts.intentHistogram}}
        {{! Bar fill — 1.1 scale so 100% → 110px height, leaving space for label }}
        <rect
          x="{{add (multiply @index 88) 4}}"
          y="{{subtract 115 (multiply pct 1.05)}}"
          width="68"
          height="{{multiply pct 1.05}}"
          fill="{{#if (greaterThan pct 30)}}#6366f1{{else}}#a5b4fc{{/if}}"
          rx="5"
        />
        <text
          x="{{add (multiply @index 88) 38}}"
          y="{{subtract 110 (multiply pct 1.05)}}"
          text-anchor="middle"
          font-size="10"
          font-weight="700"
          fill="#1e293b"
        >{{pct}}%</text>
        <text
          x="{{add (multiply @index 88) 38}}"
          y="130"
          text-anchor="middle"
          font-size="10"
          fill="#64748b"
        >★ {{score}}</text>
      {{/each}}
    </svg>
  </div>

  <div class="charts-row">
    <div class="chart-col-wide">
      <div class="chart-label">Recomendación del producto</div>
      {{#if charts.donutSlices}}
        <div style="display:flex;align-items:center;gap:20px;">
          <svg viewBox="0 0 160 160" width="160" height="160" style="flex-shrink:0;">
            {{#each charts.donutSlices}}
              <path d="{{pathD}}" fill="{{color}}" stroke="#fff" stroke-width="3" />
            {{/each}}
            <circle cx="80" cy="80" r="42" fill="#fff" />
            <text x="80" y="75" text-anchor="middle" font-size="18" font-weight="800" fill="#0f172a">{{charts.recommendation.total}}</text>
            <text x="80" y="92" text-anchor="middle" font-size="8" fill="#64748b">agentes</text>
          </svg>
          <div class="donut-legend">
            {{#each charts.donutSlices}}
              <div class="donut-legend-item">
                <div class="donut-swatch" style="background:{{color}};"></div>
                <span>{{label}}</span>
                <span class="donut-pct">{{pct}}%</span>
              </div>
            {{/each}}
          </div>
        </div>
      {{else}}
        <div style="font-size:9pt;color:#94a3b8;padding:20px 0;">Sin datos de recomendación</div>
      {{/if}}
    </div>

    <div class="chart-col-narrow">
      <div class="chart-label">Precio justo estimado</div>
      <div class="price-box">
        <div class="price-amount"><span class="price-currency">$</span>{{insights.priceConsensus}}</div>
        <div class="price-label">Consenso del panel</div>
      </div>
    </div>
  </div>
</div>
